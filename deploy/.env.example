# --- LLM provider ------------------------------------------------------
# openai_compatible covers Gemini / Groq / DeepSeek / OpenRouter / Ollama.
# Pick ONE preset below and set LLM_PROVIDER=openai_compatible.
LLM_PROVIDER=openai_compatible

# Preset A: Google Gemini (has a free tier — see README cost notes)
OPENAI_COMPAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_COMPAT_KEY=your-google-ai-studio-key
OPENAI_COMPAT_MODEL=gemini-2.5-flash

# Preset B: Groq (free tier, Llama models, very fast)
# OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# Preset C: DeepSeek (among the cheapest paid APIs)
# OPENAI_COMPAT_BASE_URL=https://api.deepseek.com/v1
# OPENAI_COMPAT_MODEL=deepseek-chat

# Preset D: Ollama self-hosted (zero token cost, needs your own hardware)
# OPENAI_COMPAT_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPAT_MODEL=qwen2.5:14b

# Fallback: Claude Haiku (set LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Cost dials ---
TOP_N_INDEX=10
DEEP_DIVES_PER_FEED=3
POVS_PER_FEED=1
ONDEMAND_DAILY_LIMIT=20

# --- App ---
DB_PATH=briefings.db
API_TOKEN=generate-a-long-random-string
APP_BASE_URL=https://appsec-feeder.example.ey.com

# --- Teams (Workflows incoming webhook URL) ---
TEAMS_WEBHOOK_URL=

# --- WhatsApp (leave disabled until InfoSec/DPO sign-off) ---
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_RECIPIENTS=+9198xxxxxxx,+9197xxxxxxx
WHATSAPP_TEMPLATE=appsec_daily_digest

# --- Admin panel (served at /admin) ---
ADMIN_TOKEN=generate-a-different-long-random-string
# --- In-container scheduler ---
PIPELINE_TIME=07:00
